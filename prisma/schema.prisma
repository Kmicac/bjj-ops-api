generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  INACTIVE
  CLOSED
}

enum BranchStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  INACTIVE
  CLOSED
  TRANSITION
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  INACTIVE
}

enum MembershipRole {
  MESTRE
  ORG_ADMIN
  ACADEMY_MANAGER
  HEAD_COACH
  INSTRUCTOR
  STAFF
  STUDENT
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REVOKED
}

enum MembershipScopeType {
  ORGANIZATION_WIDE
  SELECTED_BRANCHES
}

enum StudentStatus {
  ACTIVE
  PAUSED
  DELINQUENT
  SUSPENDED
  INACTIVE
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ClassType {
  GI
  NO_GI
  FUNDAMENTALS
  ADVANCED
  KIDS
  COMPETITION
  OPEN_MAT
  SEMINAR
  PRIVATE
}

enum ClassSessionStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  EXCUSED
}

enum PromotionType {
  BELT
  STRIPE
}

enum PromotionRequestStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum PromotionRecommendation {
  DO_NOT_RECOMMEND
  NEEDS_MORE_TIME
  RECOMMEND
  STRONGLY_RECOMMEND
}

enum PromotionTrack {
  KIDS
  ADULT
}

enum PromotionRank {
  KIDS_WHITE
  KIDS_GREY_WHITE
  KIDS_GREY
  KIDS_GREY_BLACK
  KIDS_YELLOW_WHITE
  KIDS_YELLOW
  KIDS_YELLOW_BLACK
  KIDS_ORANGE_WHITE
  KIDS_ORANGE
  KIDS_ORANGE_BLACK
  KIDS_GREEN_WHITE
  KIDS_GREEN
  KIDS_GREEN_BLACK
  ADULT_WHITE
  ADULT_BLUE
  ADULT_PURPLE
  ADULT_BROWN
  ADULT_BLACK
}

model User {
  id              String                   @id @default(cuid())
  email           String                   @unique
  // Nullable by design: bootstrap/invite can create identities before the user sets a password.
  passwordHash    String?
  firstName       String
  lastName        String
  phone           String?
  status          UserStatus               @default(ACTIVE)
  emailVerifiedAt DateTime?                @db.Timestamptz(3)
  lastLoginAt     DateTime?                @db.Timestamptz(3)
  createdAt       DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime                 @updatedAt @db.Timestamptz(3)
  deletedAt       DateTime?                @db.Timestamptz(3)

  memberships     OrganizationMembership[]
  students        Student[]
  auditLogs       AuditLog[]               @relation("AuditActor")
}

model Organization {
  id              String                   @id @default(cuid())
  name            String
  slug            String                   @unique
  description     String?
  defaultTimezone String
  status          OrganizationStatus       @default(DRAFT)
  createdAt       DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime                 @updatedAt @db.Timestamptz(3)
  deletedAt       DateTime?                @db.Timestamptz(3)

  branches        Branch[]
  memberships     OrganizationMembership[]
  students        Student[]
  classSchedules  ClassSchedule[]
  classSessions   ClassSession[]
  attendanceRecords AttendanceRecord[]
  promotionRequests PromotionRequest[]
  promotionEvaluations PromotionEvaluation[]
  publicProfiles  BranchPublicProfile[]
  auditLogs       AuditLog[]

  @@index([status])
}

model Branch {
  id                 String                   @id @default(cuid())
  organizationId     String
  name               String
  slug               String
  countryCode        String                   @db.Char(2)
  region             String?
  city               String
  addressLine1       String?
  addressLine2       String?
  postalCode         String?
  timezone           String
  headCoachMembershipId String?
  status             BranchStatus             @default(DRAFT)
  isPublicListed     Boolean                  @default(false)
  createdAt          DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime                 @updatedAt @db.Timestamptz(3)
  deletedAt          DateTime?                @db.Timestamptz(3)

  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  headCoachMembership OrganizationMembership? @relation("BranchHeadCoachMembership", fields: [headCoachMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)
  publicProfile      BranchPublicProfile?
  students           Student[]
  classSchedules     ClassSchedule[]
  classSessions      ClassSession[]
  attendanceRecords  AttendanceRecord[]
  promotionRequests   PromotionRequest[]
  primaryMemberships OrganizationMembership[] @relation("MembershipPrimaryBranch")
  membershipScopes   MembershipBranchScope[]
  auditLogs          AuditLog[]

  @@unique([id, organizationId])
  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([countryCode, city])
}

model BranchPublicProfile {
  id             String       @id @default(cuid())
  organizationId String
  branchId       String
  displayName    String?
  shortBio       String?
  publicEmail    String?
  publicPhone    String?
  whatsapp       String?
  instagram      String?
  facebook       String?
  youtube        String?
  tiktok         String?
  website        String?
  isPublished    Boolean      @default(false)
  createdAt      DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(3)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch         Branch       @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@unique([branchId])
  @@unique([branchId, organizationId])
  @@index([organizationId, isPublished])
}

model OrganizationMembership {
  id              String                  @id @default(cuid())
  organizationId  String
  userId          String
  status          MembershipStatus        @default(INVITED)
  scopeType       MembershipScopeType     @default(SELECTED_BRANCHES)
  primaryBranchId String?
  createdAt       DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime                @updatedAt @db.Timestamptz(3)

  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user            User                    @relation(fields: [userId], references: [id], onDelete: Restrict)
  primaryBranch   Branch?                 @relation("MembershipPrimaryBranch", fields: [primaryBranchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  headCoachOfBranches Branch[]            @relation("BranchHeadCoachMembership")
  instructedClassSchedules ClassSchedule[] @relation("ClassScheduleInstructorMembership")
  instructedClassSessions  ClassSession[]  @relation("ClassSessionInstructorMembership")
  proposedPromotionRequests PromotionRequest[] @relation("PromotionProposedByMembership")
  reviewedPromotionRequests PromotionRequest[] @relation("PromotionReviewedByMembership")
  updatedPromotionEvaluations PromotionEvaluation[] @relation("PromotionEvaluationUpdatedByMembership")
  branchScopes    MembershipBranchScope[]
  roles           MembershipRoleAssignment[]
  auditLogs       AuditLog[]              @relation("AuditActorMembership")

  @@unique([id, organizationId])
  @@unique([organizationId, userId])
  @@index([organizationId, status])
  @@index([userId, status])
}

model MembershipRoleAssignment {
  id             String                 @id @default(cuid())
  organizationId String
  membershipId   String
  role           MembershipRole
  createdAt      DateTime               @default(now()) @db.Timestamptz(3)

  membership     OrganizationMembership @relation(fields: [membershipId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@unique([membershipId, role])
  @@index([organizationId, role])
}

model MembershipBranchScope {
  id             String                 @id @default(cuid())
  organizationId String
  membershipId   String
  branchId       String
  createdAt      DateTime               @default(now()) @db.Timestamptz(3)

  membership     OrganizationMembership @relation(fields: [membershipId, organizationId], references: [id, organizationId], onDelete: Cascade)
  branch         Branch                 @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@unique([membershipId, branchId])
  @@index([organizationId, branchId])
}

model Student {
  id                   String        @id @default(cuid())
  organizationId       String
  primaryBranchId      String
  userId               String?
  firstName            String
  lastName             String
  email                String?
  phone                String?
  dateOfBirth          DateTime?     @db.Date
  status               StudentStatus @default(ACTIVE)
  startedBjjAt         DateTime?     @db.Date
  joinedOrganizationAt DateTime?     @db.Date
  promotionTrack       PromotionTrack @default(ADULT)
  currentBelt          PromotionRank?
  currentStripes       Int           @default(0)
  createdAt            DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime      @updatedAt @db.Timestamptz(3)
  deletedAt            DateTime?     @db.Timestamptz(3)

  organization         Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  primaryBranch        Branch        @relation(fields: [primaryBranchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  user                 User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  attendanceRecords    AttendanceRecord[]
  promotionRequests    PromotionRequest[]

  @@unique([id, organizationId])
  @@unique([organizationId, userId])
  @@index([organizationId, status])
  @@index([primaryBranchId, status])
}

model ClassSchedule {
  id                     String                 @id @default(cuid())
  organizationId         String
  branchId               String
  instructorMembershipId String
  title                  String
  classType              ClassType
  description            String?
  weekday                Weekday
  startTime              String                 @db.VarChar(5)
  endTime                String                 @db.VarChar(5)
  timezone               String
  capacity               Int?
  isActive               Boolean                @default(true)
  createdAt              DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime               @updatedAt @db.Timestamptz(3)
  deletedAt              DateTime?              @db.Timestamptz(3)

  organization           Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch                 Branch                 @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  instructorMembership   OrganizationMembership @relation("ClassScheduleInstructorMembership", fields: [instructorMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)
  sessions               ClassSession[]

  @@unique([id, organizationId])
  @@index([organizationId, branchId, weekday, isActive])
  @@index([branchId, isActive])
}

model ClassSession {
  id                     String                 @id @default(cuid())
  organizationId         String
  branchId               String
  classScheduleId        String?
  instructorMembershipId String
  title                  String
  classType              ClassType
  scheduledDate          DateTime               @db.Date
  startAt                DateTime               @db.Timestamptz(3)
  endAt                  DateTime               @db.Timestamptz(3)
  capacity               Int?
  status                 ClassSessionStatus     @default(SCHEDULED)
  cancellationReason     String?
  notes                  String?
  createdAt              DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime               @updatedAt @db.Timestamptz(3)
  deletedAt              DateTime?              @db.Timestamptz(3)

  organization           Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch                 Branch                 @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  classSchedule          ClassSchedule?         @relation(fields: [classScheduleId, organizationId], references: [id, organizationId], onDelete: Restrict)
  instructorMembership   OrganizationMembership @relation("ClassSessionInstructorMembership", fields: [instructorMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)
  attendanceRecords      AttendanceRecord[]

  @@unique([id, organizationId])
  @@index([organizationId, branchId, scheduledDate])
  @@index([branchId, startAt, status])
  @@index([classScheduleId, scheduledDate])
}

model AttendanceRecord {
  id             String           @id @default(cuid())
  organizationId String
  branchId       String
  classSessionId String
  studentId      String
  status         AttendanceStatus @default(PRESENT)
  notes          String?
  createdAt      DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @db.Timestamptz(3)

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch         Branch           @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  classSession   ClassSession     @relation(fields: [classSessionId, organizationId], references: [id, organizationId], onDelete: Restrict)
  student        Student          @relation(fields: [studentId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([id, organizationId])
  @@unique([classSessionId, studentId])
  @@index([organizationId, branchId, classSessionId])
  @@index([classSessionId, status])
  @@index([studentId, createdAt])
}

model PromotionRequest {
  id                   String                 @id @default(cuid())
  organizationId       String
  branchId             String
  studentId            String
  proposedByMembershipId String
  reviewedByMembershipId String?
  type                 PromotionType
  status               PromotionRequestStatus @default(PENDING_REVIEW)
  trackSnapshot        PromotionTrack
  currentBeltSnapshot  PromotionRank?
  currentStripesSnapshot Int
  targetBelt           PromotionRank?
  targetStripes        Int?
  proposalNotes        String?
  decisionNotes        String?
  rejectionReason      String?
  effectiveDate        DateTime?              @db.Date
  decisionAt           DateTime?              @db.Timestamptz(3)
  createdAt            DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime               @updatedAt @db.Timestamptz(3)

  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch               Branch                 @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  student              Student                @relation(fields: [studentId, organizationId], references: [id, organizationId], onDelete: Restrict)
  proposedByMembership OrganizationMembership @relation("PromotionProposedByMembership", fields: [proposedByMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)
  reviewedByMembership OrganizationMembership? @relation("PromotionReviewedByMembership", fields: [reviewedByMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)
  evaluation           PromotionEvaluation?

  @@unique([id, organizationId])
  @@index([organizationId, branchId, status])
  @@index([studentId, status])
  @@index([proposedByMembershipId, createdAt])
}

model PromotionEvaluation {
  id                           String                  @id @default(cuid())
  organizationId               String
  promotionRequestId           String
  updatedByMembershipId        String?
  classesSinceLastPromotion    Int?
  attendanceLast30Days         Int?
  attendanceLast90Days         Int?
  daysSinceLastPromotion       Int?
  approvedPromotionCount       Int?
  guardScore                   Int?
  passingScore                 Int?
  controlScore                 Int?
  escapesDefenseScore          Int?
  submissionsScore             Int?
  tacticalUnderstandingScore   Int?
  attitudeDisciplineScore      Int?
  commitmentConsistencyScore   Int?
  teamworkRespectScore         Int?
  coachNotes                   String?
  recommendation               PromotionRecommendation?
  signalsComputedAt            DateTime?               @db.Timestamptz(3)
  createdAt                    DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt                    DateTime                @updatedAt @db.Timestamptz(3)

  organization                 Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  promotionRequest             PromotionRequest        @relation(fields: [promotionRequestId, organizationId], references: [id, organizationId], onDelete: Cascade)
  updatedByMembership          OrganizationMembership? @relation("PromotionEvaluationUpdatedByMembership", fields: [updatedByMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([promotionRequestId])
  @@unique([promotionRequestId, organizationId])
  @@index([organizationId, recommendation])
}

model AuditLog {
  id                String                  @id @default(cuid())
  organizationId    String
  branchId          String?
  actorUserId       String?
  actorMembershipId String?
  requestId         String?
  ipAddress         String?
  userAgent         String?
  action            String
  entityType        String
  entityId          String
  metadata          Json?
  createdAt         DateTime                @default(now()) @db.Timestamptz(3)

  organization      Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch            Branch?                 @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  actor             User?                   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorMembership   OrganizationMembership? @relation("AuditActorMembership", fields: [actorMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
}
