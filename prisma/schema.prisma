generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  INACTIVE
  CLOSED
}

enum BranchStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  INACTIVE
  CLOSED
  TRANSITION
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  INACTIVE
}

enum MembershipRole {
  MESTRE
  ORG_ADMIN
  ACADEMY_MANAGER
  HEAD_COACH
  INSTRUCTOR
  STAFF
  STUDENT
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REVOKED
}

enum MembershipScopeType {
  ORGANIZATION_WIDE
  SELECTED_BRANCHES
}

enum StudentStatus {
  ACTIVE
  PAUSED
  DELINQUENT
  SUSPENDED
  INACTIVE
}

enum BillingFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

enum StudentMembershipStatus {
  ACTIVE
  PAUSED
  FROZEN
  CANCELED
  ENDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum BillingChargeType {
  MEMBERSHIP
  ENROLLMENT
  ADJUSTMENT
  MANUAL
}

enum BillingChargeStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELED
  VOID
}

enum PaymentKind {
  STUDENT_PAYMENT
  GENERAL_INCOME
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  DEBIT_CARD
  CREDIT_CARD
  MERCADO_PAGO
  TAKENOS
  OTHER
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
  FAILED
}

enum IntegrationProvider {
  MERCADO_PAGO
  TAKENOS
  SMOOTHCOMP
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  DISCONNECTED
}

enum IntegrationScopeType {
  ORGANIZATION
  BRANCH
}

enum IntegrationSyncKind {
  TEST_CONNECTION
  IMPORT_STUDENT_COMPETITIONS
  SYNC_PAYMENT_STATUS
  IMPORT_EXTERNAL_TRANSACTIONS
}

enum IntegrationSyncStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  PARTIALLY_SUCCEEDED
}

enum IntegrationWebhookValidationStatus {
  VALID
  INVALID
}

enum IntegrationWebhookProcessingStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  IGNORED
  FAILED
}

enum ExternalEntityType {
  STUDENT
  PAYMENT
  BILLING_CHARGE
  COMPETITION_PROFILE
  COMPETITION_EVENT
  COMPETITION_MATCH
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ClassType {
  GI
  NO_GI
  FUNDAMENTALS
  ADVANCED
  KIDS
  COMPETITION
  OPEN_MAT
  SEMINAR
  PRIVATE
}

enum ClassSessionStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  EXCUSED
}

enum PromotionType {
  BELT
  STRIPE
}

enum PromotionRequestStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum PromotionRecommendation {
  DO_NOT_RECOMMEND
  NEEDS_MORE_TIME
  RECOMMEND
  STRONGLY_RECOMMEND
}

enum PromotionTrack {
  KIDS
  ADULT
}

enum PromotionRank {
  KIDS_WHITE
  KIDS_GREY_WHITE
  KIDS_GREY
  KIDS_GREY_BLACK
  KIDS_YELLOW_WHITE
  KIDS_YELLOW
  KIDS_YELLOW_BLACK
  KIDS_ORANGE_WHITE
  KIDS_ORANGE
  KIDS_ORANGE_BLACK
  KIDS_GREEN_WHITE
  KIDS_GREEN
  KIDS_GREEN_BLACK
  ADULT_WHITE
  ADULT_BLUE
  ADULT_PURPLE
  ADULT_BROWN
  ADULT_BLACK
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  // Nullable by design: bootstrap/invite can create identities before the user sets a password.
  passwordHash    String?
  firstName       String
  lastName        String
  phone           String?
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?  @db.Timestamptz(3)
  lastLoginAt     DateTime?  @db.Timestamptz(3)
  createdAt       DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime   @updatedAt @db.Timestamptz(3)
  deletedAt       DateTime?  @db.Timestamptz(3)

  memberships OrganizationMembership[]
  students    Student[]
  auditLogs   AuditLog[]               @relation("AuditActor")
}

model Organization {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  description     String?
  defaultTimezone String
  status          OrganizationStatus @default(DRAFT)
  createdAt       DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime           @updatedAt @db.Timestamptz(3)
  deletedAt       DateTime?          @db.Timestamptz(3)

  branches             Branch[]
  memberships          OrganizationMembership[]
  students             Student[]
  classSchedules       ClassSchedule[]
  classSessions        ClassSession[]
  attendanceRecords    AttendanceRecord[]
  promotionRequests    PromotionRequest[]
  promotionEvaluations PromotionEvaluation[]
  publicProfiles       BranchPublicProfile[]
  billingPlans         BillingPlan[]
  studentMemberships   StudentMembership[]
  billingCharges       BillingCharge[]
  paymentRecords       PaymentRecord[]
  billingPolicies      BillingPolicy[]
  integrationConnections IntegrationConnection[]
  integrationSyncJobs    IntegrationSyncJob[]
  webhookEvents          IntegrationWebhookEvent[]
  externalEntityLinks    ExternalEntityLink[]
  auditLogs            AuditLog[]

  @@index([status])
}

model Branch {
  id                    String       @id @default(cuid())
  organizationId        String
  name                  String
  slug                  String
  countryCode           String       @db.Char(2)
  region                String?
  city                  String
  addressLine1          String?
  addressLine2          String?
  postalCode            String?
  timezone              String
  headCoachMembershipId String?
  status                BranchStatus @default(DRAFT)
  isPublicListed        Boolean      @default(false)
  createdAt             DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime     @updatedAt @db.Timestamptz(3)
  deletedAt             DateTime?    @db.Timestamptz(3)

  organization        Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  headCoachMembership OrganizationMembership?  @relation("BranchHeadCoachMembership", fields: [headCoachMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)
  publicProfile       BranchPublicProfile?
  students            Student[]
  classSchedules      ClassSchedule[]
  classSessions       ClassSession[]
  attendanceRecords   AttendanceRecord[]
  promotionRequests   PromotionRequest[]
  billingPlans        BillingPlan[]
  studentMemberships  StudentMembership[]
  billingCharges      BillingCharge[]
  paymentRecords      PaymentRecord[]
  billingPolicy       BillingPolicy?
  integrationConnections IntegrationConnection[]
  integrationSyncJobs    IntegrationSyncJob[]
  webhookEvents          IntegrationWebhookEvent[]
  externalEntityLinks    ExternalEntityLink[]
  primaryMemberships  OrganizationMembership[] @relation("MembershipPrimaryBranch")
  membershipScopes    MembershipBranchScope[]
  auditLogs           AuditLog[]

  @@unique([id, organizationId])
  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([countryCode, city])
}

model BranchPublicProfile {
  id             String   @id @default(cuid())
  organizationId String
  branchId       String
  displayName    String?
  shortBio       String?
  publicEmail    String?
  publicPhone    String?
  whatsapp       String?
  instagram      String?
  facebook       String?
  youtube        String?
  tiktok         String?
  website        String?
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch       @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@unique([branchId])
  @@unique([branchId, organizationId])
  @@index([organizationId, isPublished])
}

model OrganizationMembership {
  id              String              @id @default(cuid())
  organizationId  String
  userId          String
  status          MembershipStatus    @default(INVITED)
  scopeType       MembershipScopeType @default(SELECTED_BRANCHES)
  primaryBranchId String?
  createdAt       DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime            @updatedAt @db.Timestamptz(3)

  organization                Organization               @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user                        User                       @relation(fields: [userId], references: [id], onDelete: Restrict)
  primaryBranch               Branch?                    @relation("MembershipPrimaryBranch", fields: [primaryBranchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  headCoachOfBranches         Branch[]                   @relation("BranchHeadCoachMembership")
  instructedClassSchedules    ClassSchedule[]            @relation("ClassScheduleInstructorMembership")
  instructedClassSessions     ClassSession[]             @relation("ClassSessionInstructorMembership")
  proposedPromotionRequests   PromotionRequest[]         @relation("PromotionProposedByMembership")
  reviewedPromotionRequests   PromotionRequest[]         @relation("PromotionReviewedByMembership")
  updatedPromotionEvaluations PromotionEvaluation[]      @relation("PromotionEvaluationUpdatedByMembership")
  recordedPayments            PaymentRecord[]            @relation("PaymentRecordedByMembership")
  createdIntegrationConnections IntegrationConnection[]  @relation("IntegrationConnectionCreatedByMembership")
  triggeredIntegrationSyncJobs   IntegrationSyncJob[]    @relation("IntegrationSyncJobTriggeredByMembership")
  createdExternalEntityLinks     ExternalEntityLink[]    @relation("ExternalEntityLinkCreatedByMembership")
  branchScopes                MembershipBranchScope[]
  roles                       MembershipRoleAssignment[]
  auditLogs                   AuditLog[]                 @relation("AuditActorMembership")

  @@unique([id, organizationId])
  @@unique([organizationId, userId])
  @@index([organizationId, status])
  @@index([userId, status])
}

model MembershipRoleAssignment {
  id             String         @id @default(cuid())
  organizationId String
  membershipId   String
  role           MembershipRole
  createdAt      DateTime       @default(now()) @db.Timestamptz(3)

  membership OrganizationMembership @relation(fields: [membershipId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@unique([membershipId, role])
  @@index([organizationId, role])
}

model MembershipBranchScope {
  id             String   @id @default(cuid())
  organizationId String
  membershipId   String
  branchId       String
  createdAt      DateTime @default(now()) @db.Timestamptz(3)

  membership OrganizationMembership @relation(fields: [membershipId, organizationId], references: [id, organizationId], onDelete: Cascade)
  branch     Branch                 @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@unique([membershipId, branchId])
  @@index([organizationId, branchId])
}

model Student {
  id                   String         @id @default(cuid())
  organizationId       String
  primaryBranchId      String
  userId               String?
  firstName            String
  lastName             String
  email                String?
  phone                String?
  dateOfBirth          DateTime?      @db.Date
  status               StudentStatus  @default(ACTIVE)
  startedBjjAt         DateTime?      @db.Date
  joinedOrganizationAt DateTime?      @db.Date
  promotionTrack       PromotionTrack @default(ADULT)
  currentBelt          PromotionRank?
  currentStripes       Int            @default(0)
  createdAt            DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime       @updatedAt @db.Timestamptz(3)
  deletedAt            DateTime?      @db.Timestamptz(3)

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  primaryBranch      Branch              @relation(fields: [primaryBranchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  attendanceRecords  AttendanceRecord[]
  promotionRequests  PromotionRequest[]
  studentMemberships StudentMembership[]
  billingCharges     BillingCharge[]
  paymentRecords     PaymentRecord[]

  @@unique([id, organizationId])
  @@unique([organizationId, userId])
  @@index([organizationId, status])
  @@index([primaryBranchId, status])
}

model BillingPlan {
  id                  String           @id @default(cuid())
  organizationId      String
  branchId            String
  name                String
  description         String?
  billingFrequency    BillingFrequency
  amount              Decimal          @db.Decimal(12, 2)
  currency            String           @db.VarChar(3)
  enrollmentFeeAmount Decimal?         @db.Decimal(12, 2)
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime         @updatedAt @db.Timestamptz(3)
  deletedAt           DateTime?        @db.Timestamptz(3)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch              @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  memberships  StudentMembership[]
  charges      BillingCharge[]

  @@unique([id, organizationId])
  @@index([organizationId, branchId, isActive])
  @@index([branchId, billingFrequency])
}

model StudentMembership {
  id              String                  @id @default(cuid())
  organizationId  String
  branchId        String
  studentId       String
  billingPlanId   String
  status          StudentMembershipStatus @default(ACTIVE)
  startedAt       DateTime                @db.Date
  endedAt         DateTime?               @db.Date
  nextBillingDate DateTime?               @db.Date
  freezeStartAt   DateTime?               @db.Date
  freezeEndAt     DateTime?               @db.Date
  discountType    DiscountType?
  discountValue   Decimal?                @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime                @updatedAt @db.Timestamptz(3)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch          @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  student      Student         @relation(fields: [studentId, organizationId], references: [id, organizationId], onDelete: Restrict)
  billingPlan  BillingPlan     @relation(fields: [billingPlanId, organizationId], references: [id, organizationId], onDelete: Restrict)
  charges      BillingCharge[]

  @@unique([id, organizationId])
  @@index([organizationId, branchId, status])
  @@index([studentId, status])
  @@index([billingPlanId, status])
}

model BillingCharge {
  id                  String              @id @default(cuid())
  organizationId      String
  branchId            String
  studentId           String
  studentMembershipId String?
  billingPlanId       String?
  chargeType          BillingChargeType
  periodStart         DateTime?           @db.Date
  periodEnd           DateTime?           @db.Date
  dueDate             DateTime            @db.Date
  amount              Decimal             @db.Decimal(12, 2)
  amountPaid          Decimal             @default(0) @db.Decimal(12, 2)
  currency            String              @db.VarChar(3)
  status              BillingChargeStatus @default(PENDING)
  description         String?
  externalProvider    String?
  externalReference   String?
  lastExternalPaymentReference String?
  lastExternalPaymentStatus    String?
  lastExternalPaymentStatusDetail String?
  lastExternalPaymentObservedAt DateTime?   @db.Timestamptz(3)
  createdAt           DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime            @updatedAt @db.Timestamptz(3)
  deletedAt           DateTime?           @db.Timestamptz(3)

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch            Branch             @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  student           Student            @relation(fields: [studentId, organizationId], references: [id, organizationId], onDelete: Restrict)
  studentMembership StudentMembership? @relation(fields: [studentMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)
  billingPlan       BillingPlan?       @relation(fields: [billingPlanId, organizationId], references: [id, organizationId], onDelete: Restrict)
  payments          PaymentRecord[]

  @@unique([id, organizationId])
  @@index([organizationId, branchId, status])
  @@index([studentId, dueDate])
  @@index([studentMembershipId, dueDate])
  @@index([branchId, externalProvider, externalReference])
}

model PaymentRecord {
  id                     String        @id @default(cuid())
  organizationId         String
  branchId               String
  paymentKind            PaymentKind
  studentId              String?
  billingChargeId        String?
  grossAmount            Decimal       @db.Decimal(12, 2)
  netAmount              Decimal       @db.Decimal(12, 2)
  currency               String        @db.VarChar(3)
  method                 PaymentMethod
  status                 PaymentStatus @default(APPROVED)
  description            String?
  externalProvider       String?
  externalReference      String?
  recordedByMembershipId String?
  recordedAt             DateTime      @db.Timestamptz(3)
  notes                  String?
  createdAt              DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime      @updatedAt @db.Timestamptz(3)
  deletedAt              DateTime?     @db.Timestamptz(3)

  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch               Branch                 @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  student              Student?               @relation(fields: [studentId, organizationId], references: [id, organizationId], onDelete: Restrict)
  billingCharge        BillingCharge?         @relation(fields: [billingChargeId, organizationId], references: [id, organizationId], onDelete: Restrict)
  recordedByMembership OrganizationMembership? @relation("PaymentRecordedByMembership", fields: [recordedByMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([id, organizationId])
  @@index([organizationId, branchId, paymentKind, status])
  @@index([studentId, recordedAt])
  @@index([billingChargeId, recordedAt])
  @@index([branchId, externalProvider, externalReference])
}

model IntegrationConnection {
  id                    String               @id @default(cuid())
  organizationId        String
  branchId              String?
  provider              IntegrationProvider
  status                IntegrationStatus    @default(INACTIVE)
  scopeType             IntegrationScopeType
  displayName           String
  configJson            Json?
  lastSyncAt            DateTime?            @db.Timestamptz(3)
  lastSyncStatus        IntegrationSyncStatus?
  lastSyncError         String?
  createdByMembershipId String
  createdAt             DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime             @updatedAt @db.Timestamptz(3)
  deletedAt             DateTime?            @db.Timestamptz(3)

  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch               Branch?                @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  createdByMembership  OrganizationMembership @relation("IntegrationConnectionCreatedByMembership", fields: [createdByMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)
  syncJobs             IntegrationSyncJob[]
  externalEntityLinks  ExternalEntityLink[]
  webhookEvents        IntegrationWebhookEvent[]

  @@unique([id, organizationId])
  @@index([organizationId, provider, status])
  @@index([branchId, provider, status])
  @@index([organizationId, scopeType, deletedAt])
}

model IntegrationSyncJob {
  id                     String                @id @default(cuid())
  organizationId         String
  branchId               String?
  integrationConnectionId String
  provider               IntegrationProvider
  syncKind               IntegrationSyncKind
  status                 IntegrationSyncStatus @default(PENDING)
  startedAt              DateTime              @db.Timestamptz(3)
  finishedAt             DateTime?             @db.Timestamptz(3)
  triggeredByMembershipId String?
  summaryJson            Json?
  errorMessage           String?
  createdAt              DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime              @updatedAt @db.Timestamptz(3)

  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch                Branch?                  @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  integrationConnection IntegrationConnection    @relation(fields: [integrationConnectionId, organizationId], references: [id, organizationId], onDelete: Restrict)
  triggeredByMembership OrganizationMembership?  @relation("IntegrationSyncJobTriggeredByMembership", fields: [triggeredByMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([id, organizationId])
  @@index([integrationConnectionId, createdAt])
  @@index([organizationId, branchId, createdAt])
  @@index([organizationId, provider, syncKind, createdAt])
}

model IntegrationWebhookEvent {
  id                      String                            @id @default(cuid())
  provider                IntegrationProvider
  organizationId          String?
  branchId                String?
  integrationConnectionId String?
  deliveryId              String?
  notificationType        String?
  action                  String?
  externalEventId         String?
  externalResourceId      String?
  validationStatus        IntegrationWebhookValidationStatus
  validationError         String?
  processingStatus        IntegrationWebhookProcessingStatus @default(RECEIVED)
  processingError         String?
  payloadJson             Json
  resourceJson            Json?
  queryJson               Json?
  headersJson             Json?
  receivedAt              DateTime                          @default(now()) @db.Timestamptz(3)
  processedAt             DateTime?                         @db.Timestamptz(3)
  reprocessCount          Int                               @default(0)
  lastReprocessedAt       DateTime?                         @db.Timestamptz(3)
  createdAt               DateTime                          @default(now()) @db.Timestamptz(3)
  updatedAt               DateTime                          @updatedAt @db.Timestamptz(3)

  organization         Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  branch               Branch?               @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: SetNull)
  integrationConnection IntegrationConnection? @relation(fields: [integrationConnectionId, organizationId], references: [id, organizationId], onDelete: SetNull)

  @@index([provider, receivedAt])
  @@index([provider, deliveryId])
  @@index([integrationConnectionId, receivedAt])
  @@index([organizationId, branchId, receivedAt])
}

model ExternalEntityLink {
  id                    String             @id @default(cuid())
  organizationId        String
  branchId              String?
  integrationConnectionId String
  provider              IntegrationProvider
  entityType            ExternalEntityType
  internalEntityId      String
  externalEntityId      String
  externalReference     String?
  metadataJson          Json?
  createdByMembershipId String?
  createdAt             DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime           @updatedAt @db.Timestamptz(3)

  organization         Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch               Branch?                  @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  integrationConnection IntegrationConnection   @relation(fields: [integrationConnectionId, organizationId], references: [id, organizationId], onDelete: Restrict)
  createdByMembership  OrganizationMembership?  @relation("ExternalEntityLinkCreatedByMembership", fields: [createdByMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([id, organizationId])
  @@unique([integrationConnectionId, entityType, internalEntityId, externalEntityId])
  @@index([organizationId, provider, entityType])
  @@index([integrationConnectionId, entityType, createdAt])
}

model BillingPolicy {
  id                            String   @id @default(cuid())
  organizationId                String
  branchId                      String
  graceDays                     Int      @default(0)
  restrictAttendanceWhenOverdue Boolean  @default(false)
  restrictAppUsageWhenOverdue   Boolean  @default(false)
  allowFreeze                   Boolean  @default(true)
  maxFreezeDaysPerYear          Int?
  allowManualDiscounts          Boolean  @default(true)
  allowPartialPayments          Boolean  @default(true)
  createdAt                     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt                     DateTime @updatedAt @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch       @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@unique([branchId])
  @@unique([branchId, organizationId])
}

model ClassSchedule {
  id                     String    @id @default(cuid())
  organizationId         String
  branchId               String
  instructorMembershipId String
  title                  String
  classType              ClassType
  description            String?
  weekday                Weekday
  startTime              String    @db.VarChar(5)
  endTime                String    @db.VarChar(5)
  timezone               String
  capacity               Int?
  isActive               Boolean   @default(true)
  createdAt              DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt              DateTime? @db.Timestamptz(3)

  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch               Branch                 @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  instructorMembership OrganizationMembership @relation("ClassScheduleInstructorMembership", fields: [instructorMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)
  sessions             ClassSession[]

  @@unique([id, organizationId])
  @@index([organizationId, branchId, weekday, isActive])
  @@index([branchId, isActive])
}

model ClassSession {
  id                     String             @id @default(cuid())
  organizationId         String
  branchId               String
  classScheduleId        String?
  instructorMembershipId String
  title                  String
  classType              ClassType
  scheduledDate          DateTime           @db.Date
  startAt                DateTime           @db.Timestamptz(3)
  endAt                  DateTime           @db.Timestamptz(3)
  capacity               Int?
  status                 ClassSessionStatus @default(SCHEDULED)
  cancellationReason     String?
  notes                  String?
  createdAt              DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime           @updatedAt @db.Timestamptz(3)
  deletedAt              DateTime?          @db.Timestamptz(3)

  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch               Branch                 @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  classSchedule        ClassSchedule?         @relation(fields: [classScheduleId, organizationId], references: [id, organizationId], onDelete: Restrict)
  instructorMembership OrganizationMembership @relation("ClassSessionInstructorMembership", fields: [instructorMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)
  attendanceRecords    AttendanceRecord[]

  @@unique([id, organizationId])
  @@index([organizationId, branchId, scheduledDate])
  @@index([branchId, startAt, status])
  @@index([classScheduleId, scheduledDate])
}

model AttendanceRecord {
  id             String           @id @default(cuid())
  organizationId String
  branchId       String
  classSessionId String
  studentId      String
  status         AttendanceStatus @default(PRESENT)
  notes          String?
  createdAt      DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch       @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  classSession ClassSession @relation(fields: [classSessionId, organizationId], references: [id, organizationId], onDelete: Restrict)
  student      Student      @relation(fields: [studentId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([id, organizationId])
  @@unique([classSessionId, studentId])
  @@index([organizationId, branchId, classSessionId])
  @@index([classSessionId, status])
  @@index([studentId, createdAt])
}

model PromotionRequest {
  id                     String                 @id @default(cuid())
  organizationId         String
  branchId               String
  studentId              String
  proposedByMembershipId String
  reviewedByMembershipId String?
  type                   PromotionType
  status                 PromotionRequestStatus @default(PENDING_REVIEW)
  trackSnapshot          PromotionTrack
  currentBeltSnapshot    PromotionRank?
  currentStripesSnapshot Int
  targetBelt             PromotionRank?
  targetStripes          Int?
  proposalNotes          String?
  decisionNotes          String?
  rejectionReason        String?
  effectiveDate          DateTime?              @db.Date
  decisionAt             DateTime?              @db.Timestamptz(3)
  createdAt              DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime               @updatedAt @db.Timestamptz(3)

  organization         Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch               Branch                  @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  student              Student                 @relation(fields: [studentId, organizationId], references: [id, organizationId], onDelete: Restrict)
  proposedByMembership OrganizationMembership  @relation("PromotionProposedByMembership", fields: [proposedByMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)
  reviewedByMembership OrganizationMembership? @relation("PromotionReviewedByMembership", fields: [reviewedByMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)
  evaluation           PromotionEvaluation?

  @@unique([id, organizationId])
  @@index([organizationId, branchId, status])
  @@index([studentId, status])
  @@index([proposedByMembershipId, createdAt])
}

model PromotionEvaluation {
  id                         String                   @id @default(cuid())
  organizationId             String
  promotionRequestId         String
  updatedByMembershipId      String?
  classesSinceLastPromotion  Int?
  attendanceLast30Days       Int?
  attendanceLast90Days       Int?
  daysSinceLastPromotion     Int?
  approvedPromotionCount     Int?
  guardScore                 Int?
  passingScore               Int?
  controlScore               Int?
  escapesDefenseScore        Int?
  submissionsScore           Int?
  tacticalUnderstandingScore Int?
  attitudeDisciplineScore    Int?
  commitmentConsistencyScore Int?
  teamworkRespectScore       Int?
  coachNotes                 String?
  recommendation             PromotionRecommendation?
  signalsComputedAt          DateTime?                @db.Timestamptz(3)
  createdAt                  DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt                  DateTime                 @updatedAt @db.Timestamptz(3)

  organization        Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  promotionRequest    PromotionRequest        @relation(fields: [promotionRequestId, organizationId], references: [id, organizationId], onDelete: Cascade)
  updatedByMembership OrganizationMembership? @relation("PromotionEvaluationUpdatedByMembership", fields: [updatedByMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([promotionRequestId])
  @@unique([promotionRequestId, organizationId])
  @@index([organizationId, recommendation])
}

model AuditLog {
  id                String   @id @default(cuid())
  organizationId    String
  branchId          String?
  actorUserId       String?
  actorMembershipId String?
  requestId         String?
  ipAddress         String?
  userAgent         String?
  action            String
  entityType        String
  entityId          String
  metadata          Json?
  createdAt         DateTime @default(now()) @db.Timestamptz(3)

  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch          Branch?                 @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  actor           User?                   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorMembership OrganizationMembership? @relation("AuditActorMembership", fields: [actorMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
}
